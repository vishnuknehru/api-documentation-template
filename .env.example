# ─── Sandbox Mock Credentials ─────────────────────────────────────────────────
# These are pre-configured mock credentials for the sandbox environment.
# Developers use these in the Try-it console to test OAuth flows.
# Do NOT use real credentials here.
MOCK_CLIENT_ID=sandbox_client_id_abc123
MOCK_CLIENT_SECRET=sandbox_secret_xyz789
MOCK_JWT_SECRET=sandbox_jwt_signing_secret_change_in_prod

# ─── Service URLs ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANDBOX_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Content Path ─────────────────────────────────────────────────────────────
# Path where content/ folder is mounted inside Docker containers.
# Leave as-is for Docker Compose. Override for custom deployments.
CONTENT_PATH=/app/content
